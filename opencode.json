{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "amap_gis": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "amap_mcp.server"
      ],
      "enabled": true,
      "environment": {
        "AMAP_API_KEY": "{env:AMAP_API_KEY}",
        "AMAP_DOTENV_PATH": "{workspaceRoot}/.env"
      },
      "timeout": 10000
    }
  },
  "agent": {
    "gis-orchestrator": {
      "mode": "primary",
      "description": "GIS 主调度智能体 - 管理地名查询、距离量算、路径规划三个子智能体",
      "permission": {
        "task": {
          "geocoder": "allow",
          "distance-measure": "allow",
          "route-planner": "allow"
        }
      },
      "tools": {
        "amap_gis_*": false,
        "webfetch": false,
        "bash": false,
        "write": false,
        "edit": false
      }
    }
  }
}